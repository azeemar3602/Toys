  <link rel="dns-prefetch" href="https://maps.gstatic.com">

  {%- if settings.favicon != blank -%}
    <link rel="shortcut icon" href="{{ settings.favicon | img_url: '32x32' }}" type="image/png" />
  {%- endif -%}

  {%- render 'seo-title' -%}

  {%- if page_description -%}
  <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- render 'social-meta-tags' -%}

  {%- render 'font-face' -%}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <style>
:root{--toy-navy:#111936;--toy-pink:#F72568;--toy-purple:#7B4DE8;--toy-green:#1FB56D;--toy-cream:#FFFDF8;--toy-border:#ECECF3;--toy-pink-bg:#FFF0F6;--toy-purple-bg:#F4EEFF;--toy-green-bg:#EDFFF5;--toy-radius-card:16px;--toy-radius-btn:12px;--toy-radius-hero:24px;--toy-shadow-card:0 2px 12px rgba(17,25,54,0.08);--toy-shadow-hover:0 8px 28px rgba(17,25,54,0.14);--buttonRadius:12px}
body{background-color:var(--toy-cream)!important}
.toy-trust-bar{background:#f8f9fb;border-bottom:1px solid var(--toy-border);padding:7px 0;font-size:12px;color:var(--toy-navy)}
.toy-trust-bar__inner{display:flex;justify-content:center;align-items:center;gap:40px;flex-wrap:wrap;max-width:1200px;margin:0 auto;padding:0 16px}
.toy-trust-item{display:flex;align-items:center;gap:7px;font-weight:600;white-space:nowrap;font-size:11.5px}
.announcement-bar{background:var(--toy-navy)!important;color:#fff!important;font-size:12px;font-weight:500;padding:6px 0}
.announcement-text{color:#fff!important}
.site-header{box-shadow:0 1px 8px rgba(17,25,54,0.06)!important}
.section-header__title{font-weight:800;color:var(--toy-navy)}

/* ══════════════════════════════════════════════════════════
   PREMIUM PRODUCT CARDS — tpc-* classes
   ══════════════════════════════════════════════════════════ */

/* Card wrapper */
.tpc-card{
  background:#fff;
  border-radius:22px;
  border:1px solid rgba(15,23,42,0.06);
  box-shadow:0 2px 14px rgba(15,23,42,0.06);
  overflow:hidden;
  display:flex;
  flex-direction:column;
  height:auto;
  transition:box-shadow 0.25s,transform 0.25s;
}
.tpc-card:hover{
  box-shadow:0 12px 36px rgba(15,23,42,0.13);
  transform:translateY(-4px);
}

/* Image area */
.tpc-media{
  position:relative;
  background:#fff;
  border-radius:18px 18px 0 0;
  padding:18px 18px 12px;
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
  text-decoration:none!important;
  flex-shrink:0;
  min-height:220px;
}
.tpc-media__img-wrap{
  display:flex;
  align-items:center;
  justify-content:center;
  width:100%;
}
.tpc-media__img{
  max-width:78%;
  max-height:200px;
  width:auto!important;
  height:auto!important;
  object-fit:contain!important;
  display:block;
  border-radius:6px;
}
.tpc-media__img--placeholder{width:60%;opacity:0.35}

/* Badge */
.tpc-badge{
  position:absolute;
  top:12px;
  left:12px;
  z-index:2;
  display:inline-flex;
  align-items:center;
  gap:4px;
  padding:5px 11px;
  border-radius:999px;
  font-size:11px;
  font-weight:700;
  color:#fff;
  line-height:1;
  letter-spacing:0.03em;
  white-space:nowrap;
}

/* Wishlist */
.tpc-wishlist{
  position:absolute;
  top:12px;
  right:12px;
  z-index:2;
  width:40px;
  height:40px;
  border-radius:50%;
  background:#fff;
  border:1px solid rgba(15,23,42,0.08);
  box-shadow:0 4px 14px rgba(15,23,42,0.08);
  display:flex;
  align-items:center;
  justify-content:center;
  color:#111936;
  cursor:pointer;
  transition:color 0.2s,box-shadow 0.2s;
  padding:0;
}
.tpc-wishlist:hover{color:#F72568;box-shadow:0 6px 18px rgba(247,37,104,0.18)}

/* Body */
.tpc-body{
  padding:14px 16px 16px;
  display:flex;
  flex-direction:column;
}
.tpc-body__link{
  display:block;
  text-decoration:none!important;
  color:inherit;
}

/* Title — ONE LINE, ellipsis */
.tpc-title{
  font-size:15px;
  font-weight:700;
  line-height:1.3;
  color:#111936;
  margin:0 0 4px;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
  letter-spacing:-0.01em;
}

/* Subtitle */
.tpc-subtitle{
  font-size:12.5px;
  color:#6b7280;
  line-height:1.3;
  margin:0 0 8px;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}

/* Rating */
.tpc-rating{margin-bottom:8px;line-height:1}
.tpc-rating .shopify-product-reviews-badge{display:block}

/* Price row */
.tpc-price-row{
  display:flex;
  align-items:center;
  gap:8px;
  flex-wrap:wrap;
  margin:8px 0 10px;
}
.tpc-price-current{
  font-size:19px;
  font-weight:800;
  color:#111936;
  line-height:1;
}
.tpc-price-compare{
  font-size:13px;
  color:#9ca3af;
  text-decoration:line-through;
  font-weight:400;
}
.tpc-price-pill{
  font-size:11.5px;
  font-weight:700;
  color:#ec1f65;
  background:#ffe8f0;
  border-radius:999px;
  padding:4px 9px;
  line-height:1;
  white-space:nowrap;
}

/* Form reset */
.tpc-form{margin:0;padding:0}

/* ATC Button */
.tpc-atc-btn{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  width:100%;
  min-height:46px;
  border:none;
  border-radius:14px;
  background:#111936;
  color:#fff!important;
  font-size:14px;
  font-weight:800;
  letter-spacing:0.02em;
  cursor:pointer;
  text-decoration:none!important;
  transition:background 0.2s,transform 0.2s,box-shadow 0.2s;
  margin-top:0;
}
.tpc-atc-btn:hover{
  background:#ec1f65;
  transform:translateY(-1px);
  box-shadow:0 10px 24px rgba(236,31,101,0.22);
  color:#fff!important;
}
.tpc-atc-btn--soldout{background:#9ca3af;cursor:not-allowed;opacity:0.7}
.tpc-atc-btn--soldout:hover{background:#9ca3af;transform:none;box-shadow:none}
.tpc-atc-btn--select{background:#7B4DE8}
.tpc-atc-btn--select:hover{background:#ec1f65}

/* Grid gap */
.grid-uniform .grid__item{margin-bottom:24px}

@media(max-width:749px){
  .tpc-card{border-radius:18px}
  .tpc-media{padding:14px;border-radius:14px 14px 0 0}
  .tpc-media__img{max-width:82%}
  .tpc-body{padding:10px 12px 12px}
  .tpc-title{font-size:13px}
  .tpc-price-current{font-size:15px}
  .tpc-atc-btn{min-height:42px;font-size:13px;border-radius:12px}
  .grid-uniform .grid__item{margin-bottom:14px}
}

/* ── Legacy card overrides (keep theme from breaking) ─────── */
.grid-product__content{display:none!important}
/* ── END PREMIUM PRODUCT CARDS ───────────────────────────── */

.grid-product__price--original{
  font-size:12px!important;
  color:#adb5bd!important;
  text-decoration:line-through!important;
  font-weight:400!important;
}
.grid-product__price--savings{
  font-size:10.5px!important;
  color:#fff!important;
  background:var(--toy-pink)!important;
  border-radius:20px!important;
  padding:2px 8px!important;
  font-weight:700!important;
  letter-spacing:0.02em;
}

/* Badge — top-left of image */
.grid-product__tag{
  position:absolute;
  top:12px;
  left:12px;
  font-size:10px;
  font-weight:700;
  padding:4px 10px;
  border-radius:20px;
  z-index:2;
  letter-spacing:0.04em;
  text-transform:uppercase;
  display:flex;
  align-items:center;
  gap:4px;
}
.grid-product__tag--sale,.grid-product__tag--custom{background:var(--toy-pink)!important;color:#fff!important}
.grid-product__tag--best-seller{background:#f59e0b!important;color:#fff!important}
.grid-product__tag--new{background:var(--toy-green)!important;color:#fff!important}
.grid-product__tag--hot,.grid-product__tag--deal{background:#7B4DE8!important;color:#fff!important}
.grid-product__tag--sold-out{background:#6b7280!important;color:#fff!important}

/* Wishlist button — top-right */
.grid-product__wishlist-icon,
.grid-product__quick-add-wishlist{
  position:absolute!important;
  top:10px!important;
  right:10px!important;
  width:32px!important;
  height:32px!important;
  background:#fff!important;
  border-radius:50%!important;
  border:1px solid #eef0f6!important;
  display:flex!important;
  align-items:center!important;
  justify-content:center!important;
  box-shadow:0 1px 6px rgba(0,0,0,0.08)!important;
  z-index:3;
}

/* ATC Button */
.toy-atc-btn{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:7px;
  width:calc(100% - 24px);
  margin:10px 12px 14px;
  padding:11px 12px;
  background:var(--toy-navy);
  color:#fff;
  border:none;
  border-radius:12px;
  font-size:13px;
  font-weight:700;
  cursor:pointer;
  transition:background 0.2s,transform 0.15s;
  text-decoration:none;
  letter-spacing:0.02em;
}
.toy-atc-btn:hover{background:var(--toy-pink);transform:translateY(-1px);color:#fff;text-decoration:none}
.toy-atc-btn svg{width:16px;height:16px;flex-shrink:0}

@media(max-width:768px){
  .grid-product__image-mask{padding:14px 14px 8px;min-height:160px}
  .grid-product__image-mask .grid__image-ratio{width:82%}
  .grid-product__meta{padding:10px 12px 4px}
  .toy-atc-btn{margin:8px 10px 10px;width:calc(100% - 20px);font-size:12px}
}
.product-single__title{color:var(--toy-navy)!important;font-weight:800!important;font-size:clamp(22px,3vw,30px)!important}
.product-section .product__price{color:var(--toy-navy)!important;font-weight:800!important;font-size:26px!important}
.product-section .product__price.on-sale{color:var(--toy-pink)!important}
.product-single .btn--add-to-cart,.product-form__cart-submit{border-radius:var(--toy-radius-btn)!important;background:var(--toy-pink)!important;border-color:var(--toy-pink)!important;color:#fff!important;font-weight:700!important;font-size:16px!important;height:56px!important}
.toy-whatsapp-btn{display:inline-flex;align-items:center;gap:10px;background:#25D366;color:#fff;border-radius:var(--toy-radius-btn);padding:12px 22px;font-weight:700;font-size:14px;text-decoration:none;width:100%;justify-content:center;margin-top:10px}
.toy-whatsapp-btn:hover{background:#128C7E;color:#fff;text-decoration:none}
.toy-wa-track-btn{display:inline-flex;align-items:center;gap:8px;background:#25D366;color:#fff!important;border-radius:var(--toy-radius-btn);padding:11px 20px;font-weight:700;font-size:14px;text-decoration:none!important;margin:12px 0}
.toy-wa-track-btn:hover{background:#128C7E}
.site-footer{background:var(--toy-navy)!important;color:rgba(255,255,255,0.85)}
.site-footer a{color:rgba(255,255,255,0.75)}
.site-footer a:hover{color:var(--toy-pink)}
.site-footer .h4,.site-footer .footer__title{color:#fff!important;font-weight:700}
.cart__submit-controls .btn,.cart-drawer__footer .btn{border-radius:var(--toy-radius-btn)!important;background:var(--toy-pink)!important;border-color:var(--toy-pink)!important;color:#fff!important;font-weight:700!important}
.btn{border-radius:var(--toy-radius-btn)!important;font-weight:700;transition:background 0.2s,transform 0.15s}
.btn--primary,.btn[type="submit"]:not(.newsletter-form__submit){background:var(--toy-pink)!important;border-color:var(--toy-pink)!important;color:#fff!important}
input[type="text"],input[type="email"],input[type="password"],input[type="tel"],input[type="search"],textarea,select{border-radius:var(--toy-radius-btn)!important}
input:focus,textarea:focus,select:focus{border-color:var(--toy-pink)!important;box-shadow:0 0 0 3px rgba(247,37,104,0.12)!important;outline:none}
.index-section{padding-top:44px;padding-bottom:44px}
.toy-home-trust{background:#fff;border-top:1px solid var(--toy-border);border-bottom:1px solid var(--toy-border);padding:16px 0}
.toy-home-trust__inner{display:flex;justify-content:center;align-items:center;max-width:1200px;margin:0 auto;padding:0 16px}
.toy-home-trust-item{display:flex;flex:1;align-items:center;justify-content:center;gap:10px;padding:10px 16px;border-right:1px solid var(--toy-border);font-size:13px;font-weight:600;color:var(--toy-navy)}
.toy-home-trust-item:last-child{border-right:none}
.toy-home-trust-item__icon{width:36px;height:36px;background:var(--toy-pink-bg);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--toy-pink);font-size:16px}
@media(max-width:768px){.toy-trust-bar__inner{gap:14px}.toy-trust-item{font-size:10px}.grid-product__title{font-size:12px!important}.grid-product__price{font-size:13px!important}.toy-atc-btn{font-size:11.5px;padding:8px 10px}.hero__title{font-size:clamp(24px,7vw,40px)!important}.product-single__title{font-size:20px!important}.toy-home-trust__inner{flex-wrap:wrap}.toy-home-trust-item{flex:0 0 50%;border-bottom:1px solid var(--toy-border);padding:10px 8px}}

/* ══════════════════════════════════════════════════════════
   PREMIUM COLLECTION / SHOP PAGE
   ══════════════════════════════════════════════════════════ */

/* Page padding */
.collection-content { padding-top: 28px; padding-bottom: 48px; }

/* ── Sidebar ─────────────────────────────────────────────── */
.collection-sidebar {
  background: #fff;
  border-radius: 16px;
  border: 1px solid rgba(15,23,42,0.07);
  box-shadow: 0 2px 12px rgba(15,23,42,0.05);
  overflow: hidden;
  position: sticky;
  top: 12px;
  padding: 0;
}
/* Sidebar filter group */
.filter-block {
  border-bottom: 1px solid rgba(15,23,42,0.06);
  padding: 14px 18px;
}
.filter-block:last-child { border-bottom: none; }
.filter-block__title {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #111936;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}
/* Custom checkbox */
.filter-block__list li { margin-bottom: 8px; }
.filter-block__list label {
  display: flex;
  align-items: center;
  gap: 9px;
  font-size: 13px;
  color: #374151;
  cursor: pointer;
  font-weight: 500;
  transition: color 0.15s;
}
.filter-block__list label:hover { color: #F72568; }
.filter-block__list input[type="checkbox"] {
  width: 17px;
  height: 17px;
  border: 2px solid #d1d5db;
  border-radius: 5px;
  accent-color: #F72568;
  cursor: pointer;
  flex-shrink: 0;
}
/* Active filter chip count */
.filter-block__active-count {
  background: #F72568;
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  border-radius: 20px;
  padding: 1px 7px;
}

/* ── Collection Header ───────────────────────────────────── */
.collection-header {
  margin-bottom: 20px;
}
.collection-header__image-wrapper { border-radius: 16px; overflow: hidden; margin-bottom: 20px; }

/* ── Filter/Sort toolbar ─────────────────────────────────── */
.collection-filter {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10px;
  background: #fff;
  border: 1px solid rgba(15,23,42,0.07);
  border-radius: 12px;
  padding: 10px 16px;
  margin-bottom: 20px;
  box-shadow: 0 1px 6px rgba(15,23,42,0.04);
}
.collection-filter__item--count {
  font-size: 13px;
  color: #6b7280;
  font-weight: 500;
}
/* Sort dropdown */
.collection-filter__sort-container select,
.collection-sort select {
  border: 1.5px solid rgba(15,23,42,0.1);
  border-radius: 10px;
  padding: 7px 14px;
  font-size: 13px;
  color: #111936;
  font-weight: 600;
  background: #fff;
  cursor: pointer;
}
/* Filter button */
.js-drawer-open-collection-filters {
  border: 1.5px solid rgba(15,23,42,0.1) !important;
  border-radius: 10px !important;
  background: #fff !important;
  color: #111936 !important;
  font-size: 13px !important;
  font-weight: 600 !important;
  padding: 7px 14px !important;
  display: flex;
  align-items: center;
  gap: 7px;
}
.js-drawer-open-collection-filters.btn--tertiary-active {
  border-color: #F72568 !important;
  color: #F72568 !important;
  background: #fff0f6 !important;
}

/* Active filter chips */
.filter-ui--tag {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: #fff0f6;
  color: #F72568;
  border: 1px solid #fba4c0;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 600;
  padding: 4px 10px;
  text-decoration: none;
}
.filter-ui--tag:hover { background: #ffe0ec; color: #d91e59; text-decoration: none; }
.filter-ui--tag .filter-ui__remove { margin-left: 2px; font-size: 14px; line-height: 1; }
.filter-ui--tag-clear {
  font-size: 12px;
  color: #6b7280;
  font-weight: 600;
  text-decoration: underline;
  cursor: pointer;
}
.filter-ui--tag-clear:hover { color: #F72568; }

/* ── Product grid spacing ────────────────────────────────── */
.collection-grid__wrapper .grid { gap: 24px 0; }
@media (min-width: 769px) {
  .collection-grid__wrapper .grid__item { padding: 0 12px; }
}

/* ── Collection page section header ─────────────────────── */
.collection-hero__title,
.page-header--collection h1,
.collection-header h1 {
  font-size: clamp(22px, 3vw, 32px) !important;
  font-weight: 800 !important;
  color: #111936 !important;
}

/* ── Mobile improvements ─────────────────────────────────── */
@media (max-width: 768px) {
  .collection-content { padding-top: 16px; }
  .collection-filter { padding: 8px 12px; }
  .collection-grid__wrapper .grid__item { padding: 0 6px; }
  .collection-grid__wrapper .grid { gap: 14px 0; }
}
/* ── END COLLECTION PAGE ─────────────────────────────────── */

/* ══════════════════════════════════════════════════════════
   PREMIUM COLLECTION SIDEBAR — nav + filters
   ══════════════════════════════════════════════════════════ */

/* Sidebar card wrapper */
.collection-sidebar {
  background: #fff !important;
  border-radius: 20px !important;
  border: 1px solid rgba(17,25,54,0.07) !important;
  box-shadow: 0 2px 16px rgba(17,25,54,0.06) !important;
  overflow: hidden !important;
  padding: 0 !important;
}

/* Sidebar section (nav + each filter) */
.toy-sidebar-section {
  border-bottom: 1px solid rgba(17,25,54,0.07);
  padding: 16px 18px;
}
.toy-sidebar-section:last-child { border-bottom: none; }

/* Section header label */
.toy-sidebar-section__header {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #6b7280;
  margin-bottom: 12px;
  cursor: pointer;
  list-style: none;
}
.toy-sidebar-section__header::-webkit-details-marker { display: none; }
.toy-sidebar-section__header svg { color: #9ca3af; }

/* Top-level nav link (no children) */
.toy-sidebar-top-link {
  display: block;
  padding: 7px 0;
  font-size: 13px;
  font-weight: 500;
  color: #374151;
  text-decoration: none !important;
  border-radius: 8px;
  padding-left: 4px;
  transition: color 0.15s, padding-left 0.15s;
}
.toy-sidebar-top-link:hover { color: #F72568; padding-left: 8px; }
.toy-sidebar-top-link.is-active {
  color: #F72568;
  font-weight: 700;
  padding-left: 8px;
}

/* Accordion */
.toy-sidebar-accordion {
  border-bottom: 1px solid rgba(17,25,54,0.05);
  padding: 2px 0;
}
.toy-sidebar-accordion:last-child { border-bottom: none; }
.toy-sidebar-accordion__trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
  padding: 7px 4px;
  list-style: none;
  user-select: none;
}
.toy-sidebar-accordion__trigger::-webkit-details-marker { display: none; }
.toy-sidebar-accordion__title {
  font-size: 13.5px;
  font-weight: 600;
  color: #111936;
  text-decoration: none !important;
  flex: 1;
  transition: color 0.15s;
}
.toy-sidebar-accordion__title:hover { color: #F72568; }
.toy-sidebar-accordion__title.is-active { color: #F72568; }
.toy-sidebar-accordion__chevron {
  color: #9ca3af;
  transition: transform 0.2s;
  flex-shrink: 0;
}
.toy-sidebar-accordion[open] .toy-sidebar-accordion__chevron { transform: rotate(180deg); }

/* Child links */
.toy-sidebar-children {
  padding: 4px 0 8px 14px !important;
  margin: 0 !important;
}
.toy-sidebar-child-link {
  display: block;
  padding: 5px 8px;
  font-size: 12.5px;
  font-weight: 400;
  color: #6b7280;
  text-decoration: none !important;
  border-left: 2px solid transparent;
  transition: color 0.15s, border-color 0.15s, padding-left 0.15s;
}
.toy-sidebar-child-link:hover {
  color: #F72568;
  border-left-color: #F72568;
  padding-left: 12px;
}
.toy-sidebar-child-link.is-active {
  color: #F72568;
  font-weight: 600;
  border-left-color: #F72568;
  padding-left: 12px;
}

/* Active filter tags */
.toy-sidebar-active-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding: 12px 18px 0;
  margin: 0 !important;
}
.toy-active-tag { list-style: none; }
.toy-active-tag__link {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: #fff0f6;
  color: #F72568;
  border: 1px solid #fba4c0;
  border-radius: 999px;
  font-size: 11.5px;
  font-weight: 600;
  padding: 4px 10px;
  text-decoration: none !important;
  transition: background 0.15s;
}
.toy-active-tag__link:hover { background: #ffe0ec; color: #d91e59; }

/* Premium filter list checkboxes */
.toy-filter-list { margin: 0; padding: 0; }
.toy-filter-item { list-style: none; margin-bottom: 6px; }
.toy-filter-label {
  display: flex;
  align-items: center;
  gap: 9px;
  cursor: pointer;
  user-select: none;
}
.toy-filter-checkbox { display: none; }
.toy-filter-check {
  width: 18px;
  height: 18px;
  border: 2px solid #d1d5db;
  border-radius: 5px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border-color 0.15s, background 0.15s;
  background: #fff;
}
.toy-filter-checkbox:checked + .toy-filter-check {
  border-color: #F72568;
  background: #F72568;
}
.toy-filter-checkbox:checked + .toy-filter-check::after {
  content: '';
  width: 10px;
  height: 6px;
  border-left: 2px solid #fff;
  border-bottom: 2px solid #fff;
  transform: rotate(-45deg) translateY(-1px);
  display: block;
}
.toy-filter-text {
  font-size: 13px;
  font-weight: 500;
  color: #374151;
  line-height: 1.3;
}
.toy-filter-count { color: #9ca3af; font-size: 11.5px; }
.toy-filter-label:hover .toy-filter-text { color: #F72568; }
.toy-filter-label:hover .toy-filter-check { border-color: #F72568; }

/* Filter section open/close body */
.toy-sidebar-filter-body { padding: 8px 0 4px; }
.toy-sidebar-section--filter { padding: 12px 18px; }

/* Price range styling override */
.price-range { margin-top: 8px; }
.price-range__display-wrapper {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  font-weight: 600;
  color: #111936;
  margin-bottom: 8px;
}

/* Price apply + quick chips */
.toy-price-apply-btn {
  width: 100%;
  margin-top: 12px;
  padding: 9px 0;
  background: #111936;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.2s;
}
.toy-price-apply-btn:hover { background: #F72568; }
.toy-price-quick { margin-top: 14px; }
.toy-price-quick__label {
  font-size: 10.5px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: #9ca3af;
  margin-bottom: 8px;
}
.toy-price-quick__chips { display: flex; flex-wrap: wrap; gap: 6px; }
.toy-price-chip {
  display: inline-block;
  padding: 5px 10px;
  background: #f3f4f6;
  color: #374151;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  font-size: 11.5px;
  font-weight: 600;
  text-decoration: none !important;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.toy-price-chip:hover { background: #fff0f6; color: #F72568; border-color: #fba4c0; }

/* ── Mobile sidebar drawer improvements ─────────────────── */
@media (max-width: 768px) {
  .toy-sidebar-section { padding: 12px 14px; }
  .toy-sidebar-accordion__title { font-size: 13px; }
  .toy-sidebar-child-link { font-size: 12px; }
}
/* ── END SIDEBAR ─────────────────────────────────────────── */
</style>
