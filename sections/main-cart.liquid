{{ 'cart-checkout-design.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  ══ Toylicious Checkout-Style Cart Page ══════════════════════
  Premium pre-checkout experience. Customer details are saved
  as order notes, then user proceeds to Shopify secure checkout.
{%- endcomment -%}

<div class="tck-checkout-page">

  {%- comment -%}── Header ──{%- endcomment -%}
  <div class="tck-checkout-header">
    <div class="tck-checkout-header__inner">
      <div class="tck-checkout-header__brand">
        <a href="/" class="tck-checkout-header__logo">
          {%- if settings.logo -%}
            <img src="{{ settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}" style="height:32px;width:auto;">
          {%- else -%}
            {{ shop.name }}
          {%- endif -%}
        </a>
        <span class="tck-checkout-header__badge">
          <svg class="tck-checkout-header__lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          Secure Checkout
        </span>
      </div>
      <a href="/collections/all" class="tck-checkout-header__continue">← Continue Shopping</a>
    </div>
  </div>

  {%- if cart.item_count > 0 -%}

    {%- comment -%}── Step Indicator ──{%- endcomment -%}
    <div class="tck-steps">
      <div class="tck-steps__bar">
        <div class="tck-step is-active">
          <span class="tck-step__number">1</span>
          <span>Review</span>
        </div>
        <div class="tck-step__connector"></div>
        <div class="tck-step">
          <span class="tck-step__number">2</span>
          <span>Information</span>
        </div>
        <div class="tck-step__connector"></div>
        <div class="tck-step">
          <span class="tck-step__number">3</span>
          <span>Payment</span>
        </div>
      </div>
    </div>

    <form id="TckCheckoutForm" class="tck-checkout-body" novalidate>

      {%- comment -%}═══ LEFT COLUMN — Customer Details + Payment ═══{%- endcomment -%}
      <div class="tck-checkout-left">

        {%- comment -%}── Customer Details ──{%- endcomment -%}
        <div class="tck-card">
          <h2 class="tck-card__title">Customer Details</h2>
          <div class="tck-form-row">
            <div class="tck-form-group">
              <label for="tck-name">Full Name</label>
              <input type="text" id="tck-name" placeholder="Enter your full name" autocomplete="name">
            </div>
            <div class="tck-form-group">
              <label for="tck-phone">Phone Number</label>
              <input type="tel" id="tck-phone" placeholder="03XX XXXXXXX" autocomplete="tel">
            </div>
          </div>
          <div class="tck-form-group">
            <label for="tck-address">Delivery Address</label>
            <textarea id="tck-address" rows="2" placeholder="House/Flat, Street, Area" autocomplete="street-address"></textarea>
          </div>
          <div class="tck-form-group">
            <label for="tck-city">City</label>
            <select id="tck-city">
              <option value="">Select city</option>
              <option value="Karachi">Karachi</option>
              <option value="Lahore">Lahore</option>
              <option value="Islamabad">Islamabad</option>
              <option value="Rawalpindi">Rawalpindi</option>
              <option value="Faisalabad">Faisalabad</option>
              <option value="Multan">Multan</option>
              <option value="Peshawar">Peshawar</option>
              <option value="Quetta">Quetta</option>
              <option value="Sialkot">Sialkot</option>
              <option value="Gujranwala">Gujranwala</option>
              <option value="Hyderabad">Hyderabad</option>
              <option value="Bahawalpur">Bahawalpur</option>
              <option value="Sargodha">Sargodha</option>
              <option value="Sukkur">Sukkur</option>
              <option value="Larkana">Larkana</option>
              <option value="Abbottabad">Abbottabad</option>
              <option value="Mardan">Mardan</option>
              <option value="Sahiwal">Sahiwal</option>
              <option value="Gujrat">Gujrat</option>
              <option value="Jhang">Jhang</option>
              <option value="Other">Other</option>
            </select>
          </div>
        </div>

        {%- comment -%}── Payment Method ──{%- endcomment -%}
        <div class="tck-card">
          <h2 class="tck-card__title">Payment Method</h2>
          <div class="tck-payment-options">
            <label class="tck-payment-option is-selected">
              <input type="radio" name="tck_payment" value="Cash on Delivery" checked>
              <span class="tck-payment-option__icon">💵</span>
              <div>
                <div class="tck-payment-option__text">Cash on Delivery</div>
                <div class="tck-payment-option__desc">Pay when your order arrives</div>
              </div>
            </label>
            <label class="tck-payment-option">
              <input type="radio" name="tck_payment" value="Bank Transfer">
              <span class="tck-payment-option__icon">🏦</span>
              <div>
                <div class="tck-payment-option__text">Bank Transfer</div>
                <div class="tck-payment-option__desc">Transfer to our bank account</div>
              </div>
            </label>
          </div>
        </div>

        {%- comment -%}── Checkout CTA (mobile hidden, shown below summary on desktop) ──{%- endcomment -%}
        <div class="tck-checkout-cta-desktop" style="display:none;">
          <button type="submit" class="tck-checkout-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            Proceed to Secure Checkout
          </button>
          <div class="tck-secure-note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Your payment information is secure &amp; encrypted
          </div>
        </div>

      </div>

      {%- comment -%}═══ RIGHT COLUMN — Order Summary ═══{%- endcomment -%}
      <div class="tck-checkout-right">
        <div class="tck-card tck-order-summary">
          <h2 class="tck-card__title">Order Summary ({{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }})</h2>

          {%- for item in cart.items -%}
            <div class="tck-item" data-key="{{ item.key }}">
              <img class="tck-item__img"
                   src="{{ item.image | image_url: width: 200 }}"
                   alt="{{ item.product.title | escape }}"
                   loading="lazy">

              <div class="tck-item__details">
                <div class="tck-item__name">{{ item.product.title }}</div>

                {%- unless item.product.has_only_default_variant -%}
                  <div class="tck-item__variant">
                    {%- for option in item.options_with_values -%}
                      {{ option.name }}: {{ option.value }}{% unless forloop.last %}, {% endunless %}
                    {%- endfor -%}
                  </div>
                {%- endunless -%}

                <div class="tck-item__qty-row">
                  <div class="tck-item__qty-control">
                    <button type="button" class="tck-item__qty-btn" data-tck-qty-btn="minus" aria-label="Decrease">−</button>
                    <input type="number" class="tck-item__qty-val" value="{{ item.quantity }}" min="1" aria-label="Quantity">
                    <button type="button" class="tck-item__qty-btn" data-tck-qty-btn="plus" aria-label="Increase">+</button>
                  </div>
                  <button type="button" class="tck-item__remove" data-tck-remove>Remove</button>
                </div>

                {%- comment -%} Bundle discount badge ─────────── {%- endcomment -%}
                {%- if item.line_level_discount_allocations != blank -%}
                  {%- for discount_allocation in item.line_level_discount_allocations -%}
                    <div class="tck-item__bundle">
                      🏷️ {{ discount_allocation.discount_application.title }}
                      (-{{ discount_allocation.amount | money }})
                    </div>
                  {%- endfor -%}
                {%- endif -%}
              </div>

              <div class="tck-item__prices">
                <div class="tck-item__price">{{ item.final_line_price | money }}</div>
                {%- if item.original_line_price != item.final_line_price -%}
                  <div class="tck-item__compare">{{ item.original_line_price | money }}</div>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}

          {%- comment -%}── Cart-level discount (bundle) ──{%- endcomment -%}
          {%- if cart.cart_level_discount_applications != blank -%}
            {%- for cart_discount in cart.cart_level_discount_applications -%}
              <div class="tck-item__bundle" style="margin-top:12px;">
                🎉 {{ cart_discount.title }} (-{{ cart_discount.total_allocated_amount | money }})
              </div>
            {%- endfor -%}
          {%- endif -%}

          {%- comment -%}── Totals ──{%- endcomment -%}
          <div class="tck-totals">
            <div class="tck-totals__row">
              <span class="tck-totals__label">Subtotal</span>
              <span class="tck-totals__value">{{ cart.original_total_price | money }}</span>
            </div>

            {%- if cart.total_discount > 0 -%}
              <div class="tck-totals__row tck-totals__row--discount">
                <span class="tck-totals__label">Bundle Discount</span>
                <span class="tck-totals__value">-{{ cart.total_discount | money }}</span>
              </div>
            {%- endif -%}

            <div class="tck-totals__row">
              <span class="tck-totals__label">Delivery</span>
              <span class="tck-totals__value" style="color:var(--tck-gray-light);">Calculated at checkout</span>
            </div>

            <div class="tck-totals__row tck-totals__row--total">
              <span>Total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
          </div>

          {%- comment -%}── CTA Button (inside summary) ──{%- endcomment -%}
          <button type="submit" class="tck-checkout-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            Proceed to Secure Checkout
          </button>

          <div class="tck-secure-note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Your payment information is secure &amp; encrypted
          </div>
        </div>

        {%- comment -%}── WhatsApp Help ──{%- endcomment -%}
        {%- assign wa_number = settings.whatsapp_number | default: '923376246084' | remove: '+' | remove: ' ' | remove: '-' -%}
        <div class="tck-whatsapp-help">
          Need help?
          <a href="https://wa.me/{{ wa_number }}?text={{ 'Hi! I need help with my order on Toylicious.pk' | url_encode }}" target="_blank" rel="noopener">
            💬 Chat with us on WhatsApp
          </a>
        </div>
      </div>

    </form>

  {%- else -%}

    {%- comment -%}── Empty Cart ──{%- endcomment -%}
    <div class="tck-empty-cart">
      <div class="tck-empty-cart__icon">🛒</div>
      <h2 class="tck-empty-cart__title">Your cart is empty</h2>
      <p class="tck-empty-cart__text">Looks like you haven't added any toys yet!</p>
      <a href="/collections/all" class="tck-empty-cart__btn">
        Start Shopping →
      </a>
    </div>

  {%- endif -%}

</div>

<script src="{{ 'cart-checkout-design.js' | asset_url }}" defer="defer"></script>

{%- comment -%}
  Add class to body for overriding default theme cart styles
{%- endcomment -%}
<script>document.body.classList.add('tck-checkout-active');</script>

{% schema %}
  {
    "name": "Cart page"
  }
{% endschema %}
