{%- liquid
  assign main_menu = linklists[section.settings.main_menu_link_list]
  assign toolbar_menu = linklists[section.settings.toolbar_menu]
  assign logo_alignment = 'left'
  assign template_name = template | replace: '.', ' ' | truncatewords: 2, '' | handle
  assign sticky_header = false
  if section.settings.header_style == 'sticky'
    assign sticky_header = true
  endif
-%}

{%- render 'drawer-menu',
  section: section,
  main_menu: main_menu,
  toolbar_menu: toolbar_menu,
  logo_alignment: logo_alignment
-%}
{%- render 'cart-drawer' -%}

<style>
/* ============================================================
   TOYLICIOUS PREMIUM HEADER — Complete Rebuild
   ============================================================ */

/* Reset any old header conflicts */
#HeaderWrapper, .header-sticky-wrapper { display: none !important; }

/* ── Trust Bar ─────────────────────────────────────────────── */
.toy-hdr-trust {
  background: #fff8fb;
  border-bottom: 1px solid #ffe4ef;
  height: 34px;
  display: flex;
  align-items: center;
}
.toy-hdr-trust__inner {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 32px;
  max-width: 1300px;
  margin: 0 auto;
  padding: 0 20px;
  width: 100%;
}
.toy-hdr-trust-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11.5px;
  font-weight: 600;
  color: #111936;
  white-space: nowrap;
}
.toy-hdr-trust-item svg { flex-shrink: 0; }
@media (max-width: 768px) { .toy-hdr-trust { display: none; } }

/* ── Main Header ───────────────────────────────────────────── */
.toy-hdr-main {
  background: #fff;
  border-bottom: 1px solid #ECECF3;
  padding: 10px 0;
}
.toy-hdr-main__inner {
  display: flex;
  align-items: center;
  gap: 20px;
  max-width: 1300px;
  margin: 0 auto;
  padding: 0 24px;
}

/* Logo */
.toy-hdr-logo { flex: 0 0 auto; text-decoration: none; }
.toy-hdr-logo img {
  max-height: 56px;
  width: auto;
  display: block;
}
.toy-hdr-logo__text {
  font-size: 24px;
  font-weight: 800;
  color: #111936;
  text-decoration: none;
}

/* Search */
.toy-hdr-search {
  flex: 1;
  max-width: 580px;
  margin: 0 auto;
}
.toy-hdr-search form {
  display: flex;
  border: 2px solid #ECECF3;
  border-radius: 50px;
  overflow: hidden;
  background: #f8f9fb;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.toy-hdr-search form:focus-within {
  border-color: #F72568;
  background: #fff;
  box-shadow: 0 0 0 3px rgba(247,37,104,0.08);
}
.toy-hdr-search input[type="search"] {
  flex: 1;
  border: none !important;
  background: transparent !important;
  padding: 11px 18px;
  font-size: 13.5px;
  color: #111936;
  outline: none !important;
  box-shadow: none !important;
  border-radius: 0 !important;
  min-width: 0;
}
.toy-hdr-search input::placeholder { color: #adb5bd; font-size: 13px; }
.toy-hdr-search__submit {
  background: #F72568;
  border: none;
  border-radius: 0 48px 48px 0;
  padding: 0 20px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  transition: background 0.2s;
  flex-shrink: 0;
  gap: 6px;
  font-size: 13px;
  font-weight: 600;
}
.toy-hdr-search__submit:hover { background: #d91e59; }
.toy-hdr-search__submit svg { width: 17px; height: 17px; }

/* Icons */
.toy-hdr-icons {
  display: flex;
  align-items: center;
  gap: 4px;
  flex: 0 0 auto;
}
.toy-hdr-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 6px 10px;
  border-radius: 10px;
  color: #111936;
  text-decoration: none !important;
  transition: background 0.18s, color 0.18s;
  position: relative;
  cursor: pointer;
  border: none;
  background: transparent;
  min-width: 52px;
}
.toy-hdr-icon:hover { background: #fff0f6; color: #F72568; }
.toy-hdr-icon svg { width: 22px; height: 22px; }
.toy-hdr-icon__label {
  font-size: 10px;
  font-weight: 600;
  line-height: 1;
  color: inherit;
}
.toy-hdr-badge {
  position: absolute;
  top: 2px;
  right: 4px;
  background: #F72568;
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  border-radius: 20px;
  min-width: 16px;
  height: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 3px;
  line-height: 1;
  border: 2px solid #fff;
}

/* ── Nav Bar ───────────────────────────────────────────────── */
.toy-hdr-nav {
  background: #fff;
  border-bottom: 2px solid #ECECF3;
  box-shadow: 0 2px 8px rgba(17,25,54,0.04);
}
.toy-hdr-nav__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: 1300px;
  margin: 0 auto;
  padding: 0 24px;
}
.toy-nav-lnk {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 11px 13px;
  font-size: 13px;
  font-weight: 600;
  color: #111936;
  text-decoration: none !important;
  border-bottom: 2.5px solid transparent;
  margin-bottom: -2px;
  white-space: nowrap;
  transition: color 0.18s, border-color 0.18s;
}
.toy-nav-lnk:hover { color: #F72568; border-bottom-color: #F72568; }
.toy-nav-lnk svg { width: 13px; height: 13px; flex-shrink: 0; opacity: 0.75; }
.toy-nav-lnk--deals { color: #F72568; }
.toy-nav-lnk--deals:hover { color: #d91e59; }
.toy-nav-lnk--sale { color: #7B4DE8; }
.toy-nav-lnk--sale:hover { color: #6a3dd4; }
@media (max-width: 768px) { .toy-hdr-main, .toy-hdr-nav { display: none; } }

/* ── Sticky ────────────────────────────────────────────────── */
.toy-hdr-sticky {
  position: sticky;
  top: 0;
  z-index: 1000;
  box-shadow: 0 2px 12px rgba(17,25,54,0.10);
}

/* ── Mobile Header ─────────────────────────────────────────── */
.toy-mob-hdr {
  display: none;
  background: #fff;
  border-bottom: 1px solid #ECECF3;
}
.toy-mob-hdr__row1 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 14px;
}
.toy-mob-hdr__row2 { padding: 0 12px 10px; }
.toy-mob-search {
  display: flex;
  border: 2px solid #ECECF3;
  border-radius: 50px;
  overflow: hidden;
  background: #f8f9fb;
}
.toy-mob-search input {
  flex: 1;
  border: none !important;
  background: transparent !important;
  padding: 9px 14px;
  font-size: 13px;
  outline: none !important;
  box-shadow: none !important;
  border-radius: 0 !important;
}
.toy-mob-search button {
  background: #F72568;
  border: none;
  border-radius: 0 48px 48px 0;
  padding: 0 16px;
  color: #fff;
  cursor: pointer;
  display: flex;
  align-items: center;
}
.toy-mob-burger, .toy-mob-cart-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  color: #111936;
  display: flex;
  align-items: center;
  position: relative;
}
.toy-mob-logo img { max-height: 38px; width: auto; display: block; }
.toy-mob-logo__text { font-size: 18px; font-weight: 800; color: #111936; }
@media (max-width: 768px) { .toy-mob-hdr { display: block; } }
</style>

<!-- ══ TRUST BAR ══════════════════════════════════════════════ -->
<div class="toy-hdr-trust">
  <div class="toy-hdr-trust__inner">
    <div class="toy-hdr-trust-item">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="#1FB56D" viewBox="0 0 16 16"><path d="M0 3.5A1.5 1.5 0 0 1 1.5 2h9A1.5 1.5 0 0 1 12 3.5V5h1.02a1.5 1.5 0 0 1 1.17.563l1.481 1.85a1.5 1.5 0 0 1 .329.938V10.5a1.5 1.5 0 0 1-1.5 1.5H14a2 2 0 1 1-4 0H5a2 2 0 1 1-3.998-.085A1.5 1.5 0 0 1 0 10.5v-7zm1.294 7.456A2 2 0 0 1 4 10.5V10h6.732A2 2 0 0 1 13 8.83V7.4l-1.48-1.85a.5.5 0 0 0-.39-.187H12V7h-1V3.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5v7a.5.5 0 0 0 .294.456z"/></svg>
      Delivery Across Pakistan
    </div>
    <div class="toy-hdr-trust-item">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="#F72568" viewBox="0 0 16 16"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v1H0V4zm0 3h16v5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V7zm3 2a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5H3z"/></svg>
      Cash on Delivery
    </div>
    <div class="toy-hdr-trust-item">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="#7B4DE8" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/></svg>
      Easy Returns
    </div>
    <div class="toy-hdr-trust-item">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="#25D366" viewBox="0 0 16 16"><path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/></svg>
      WhatsApp Support
    </div>
  </div>
</div>

<!-- ══ STICKY WRAPPER ════════════════════════════════════════ -->
<div class="toy-hdr-sticky" id="ToyHeader">

  <!-- ── MAIN HEADER (DESKTOP) ─────────────────────────────── -->
  <div class="toy-hdr-main">
    <div class="toy-hdr-main__inner">

      <!-- Logo -->
      <a class="toy-hdr-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'logo' -%}
            {%- if block.settings.logo != blank -%}
              <img src="{{ block.settings.logo | img_url: '300x' }}"
                   srcset="{{ block.settings.logo | img_url: '200x' }} 200w, {{ block.settings.logo | img_url: '300x' }} 300w"
                   sizes="(max-width:1200px) 200px, 300px"
                   alt="{{ shop.name }}"
                   style="max-width:{{ block.settings.desktop_logo_width | default: 180 }}px; max-height:56px; width:auto; height:auto;"
                   loading="eager">
            {%- else -%}
              <span class="toy-hdr-logo__text">{{ shop.name }}</span>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if section.blocks.size == 0 -%}
          <span class="toy-hdr-logo__text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <!-- Search Bar -->
      <div class="toy-hdr-search">
        <form action="{{ routes.search_url }}" method="get" role="search" id="ToyHeaderSearch">
          <input type="hidden" name="type" value="{{ settings.search_type | default: 'product' }}">
          <input type="search" name="q"
                 value="{{ search.terms | escape | replace: '*', '' }}"
                 placeholder="Search for toys, categories or brands..."
                 autocomplete="off"
                 aria-label="Search">
          <button type="submit" class="toy-hdr-search__submit" aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="m21 21-4.35-4.35"/></svg>
            <span class="small--hide">Search</span>
          </button>
        </form>
      </div>

      <!-- Icons -->
      <div class="toy-hdr-icons">
        <a href="{{ routes.account_url }}" class="toy-hdr-icon" aria-label="Account">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span class="toy-hdr-icon__label">Account</span>
        </a>

        <a href="/collections/all?view=wishlist" class="toy-hdr-icon" aria-label="Wishlist">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span class="toy-hdr-icon__label">Wishlist</span>
        </a>

        <a href="{{ routes.cart_url }}" class="toy-hdr-icon js-drawer-open-cart" aria-label="Cart ({{ cart.item_count }} items)">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path stroke-linecap="round" d="M16 10a4 4 0 0 1-8 0"/></svg>
          {%- if cart.item_count > 0 -%}
            <span class="toy-hdr-badge" aria-label="{{ cart.item_count }} items">{{ cart.item_count }}</span>
          {%- endif -%}
          <span class="toy-hdr-icon__label">Cart</span>
        </a>
      </div>
    </div>
  </div>

  <!-- ── NAV BAR (DESKTOP) ──────────────────────────────────── -->
  <nav class="toy-hdr-nav" aria-label="Main navigation">
    <div class="toy-hdr-nav__inner">
      <a href="/collections/all" class="toy-nav-lnk">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h7"/></svg>
        All Toys
      </a>
      <a href="/collections/boys" class="toy-nav-lnk">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        By Age
      </a>
      <a href="/collections/learning-toys" class="toy-nav-lnk">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path stroke-linecap="round" d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        Learning Toys
      </a>
      <a href="/collections/gifts" class="toy-nav-lnk">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><path d="M12 22V7m0 0H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7zm0 0h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
        Gifts
      </a>
      <a href="/collections/new-arrivals" class="toy-nav-lnk">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        New Arrivals
      </a>
      <a href="/collections/deals" class="toy-nav-lnk toy-nav-lnk--deals">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        🔥 Deals
      </a>
      <a href="/collections/clearance-sale" class="toy-nav-lnk toy-nav-lnk--sale">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
        Clearance Sale
      </a>
      <a href="/pages/order-tracking" class="toy-nav-lnk">Order Tracking</a>
      <a href="/pages/faqs" class="toy-nav-lnk">FAQs</a>
    </div>
  </nav>

</div><!-- end sticky -->

<!-- ══ MOBILE HEADER ════════════════════════════════════════ -->
<div class="toy-mob-hdr">
  <div class="toy-mob-hdr__row1">
    <!-- Hamburger -->
    <button type="button" class="toy-mob-burger js-drawer-open-nav" aria-controls="NavDrawer" aria-label="Open menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    <!-- Logo -->
    <a class="toy-mob-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'logo' -%}
          {%- if block.settings.logo != blank -%}
            <img src="{{ block.settings.logo | img_url: '200x' }}"
                 alt="{{ shop.name }}"
                 style="max-height:38px;width:auto;">
          {%- else -%}
            <span class="toy-mob-logo__text">{{ shop.name }}</span>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </a>

    <!-- Cart -->
    <a href="{{ routes.cart_url }}" class="toy-mob-cart-btn js-drawer-open-cart" aria-label="Cart">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path stroke-linecap="round" d="M16 10a4 4 0 0 1-8 0"/></svg>
      {%- if cart.item_count > 0 -%}
        <span class="toy-hdr-badge" style="top:-4px;right:-4px;border:2px solid #fff;">{{ cart.item_count }}</span>
      {%- endif -%}
    </a>
  </div>

  <!-- Mobile Search -->
  <div class="toy-mob-hdr__row2">
    <form class="toy-mob-search" action="{{ routes.search_url }}" method="get" role="search">
      <input type="hidden" name="type" value="{{ settings.search_type | default: 'product' }}">
      <input type="search" name="q"
             placeholder="Search toys, brands, age groups..."
             autocomplete="off"
             aria-label="Search">
      <button type="submit" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </button>
    </form>
  </div>
</div>

<!-- Keep data attribute for Shopify section -->
<div data-section-id="{{ section.id }}" data-section-type="header" style="display:none;"></div>

{%- render 'announcement-bar', section: section -%}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "main_menu_link_list",
      "label": "Navigation",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "mega_menu_images",
      "label": "Show mega menu images",
      "default": true
    },
    {
      "type": "select",
      "id": "main_menu_alignment",
      "label": "Header layout",
      "default": "left",
      "options": [
        { "value": "left", "label": "Logo left, menu left" },
        { "value": "center-drawer", "label": "Logo center, menu drawer" }
