{%- liquid
  assign desktop_src = 'https://cdn.shopify.com/s/files/1/0739/3080/1378/files/toylicious-pakistan-kids-toys-online-hero-desktop_1.webp?v=1780527596'
  assign mobile_src  = 'https://cdn.shopify.com/s/files/1/0739/3080/1378/files/toylicious-pakistan-kids-toys-online-hero-desktop.webp?v=1780527597'
  assign hero_link   = section.settings.link | default: '/collections/all'
  assign hero_alt    = section.settings.alt | default: 'Shop Kids Toys Online in Pakistan - Toylicious.pk'

  if section.settings.desktop_image != blank
    assign desktop_src = section.settings.desktop_image | img_url: '2048x'
  endif
  if section.settings.mobile_image != blank
    assign mobile_src = section.settings.mobile_image | img_url: '800x'
  endif
-%}

<style>
.toy-hero-wrap {
  display: block !important;
  width: 100%;
  line-height: 0;
  overflow: hidden;
  text-decoration: none !important;
  font-size: 0;
}
.toy-hero-desktop,
.toy-hero-mobile {
  display: block;
  width: 100% !important;
  height: auto !important;
  max-width: 100%;
  border: none;
  outline: none;
}
.toy-hero-mobile { display: none !important; }

@media (max-width: 767px) {
  .toy-hero-desktop { display: none !important; }
  .toy-hero-mobile  { display: block !important; }
}
</style>

<a href="{{ hero_link }}" class="toy-hero-wrap" aria-label="{{ hero_alt }}">

  {{- '<!-- Desktop Hero -->' }}
  <img
    class="toy-hero-desktop"
    src="{{ desktop_src }}"
    alt="{{ hero_alt }}"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    width="2048">

  {{- '<!-- Mobile Hero -->' }}
  <img
    class="toy-hero-mobile"
    src="{{ mobile_src }}"
    alt="{{ hero_alt }}"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    width="800">

</a>

<!-- ══ TRUST STRIP AFTER HERO ══════════════════════════════ -->
<div class="toy-trust-strip">
  <div class="toy-trust-strip__inner">

    <div class="toy-ts-item">
      <div class="toy-ts-icon toy-ts-icon--green">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
      </div>
      <div class="toy-ts-text">
        <strong>Safe &amp; Non-Toxic</strong>
        <span>100% child safe materials</span>
      </div>
    </div>

    <div class="toy-ts-divider"></div>

    <div class="toy-ts-item">
      <div class="toy-ts-icon toy-ts-icon--yellow">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636-.707.707M21 12h-1M4 12H3m3.343-5.657-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
      </div>
      <div class="toy-ts-text">
        <strong>Learning &amp; Development</strong>
        <span>Toys that build bright futures</span>
      </div>
    </div>

    <div class="toy-ts-divider"></div>

    <div class="toy-ts-item">
      <div class="toy-ts-icon toy-ts-icon--pink">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 0 0 0 6.364L12 20.364l7.682-7.682a4.5 4.5 0 0 0-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 0 0-6.364 0z"/></svg>
      </div>
      <div class="toy-ts-text">
        <strong>Trusted by Parents</strong>
        <span>Loved by 50,000+ families</span>
      </div>
    </div>

    <div class="toy-ts-divider"></div>

    <div class="toy-ts-item">
      <div class="toy-ts-icon toy-ts-icon--blue">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h1m8-1a1 1 0 0 1-1 1H9m4-1V8a1 1 0 0 1 1-1h2.586a1 1 0 0 1 .707.293l3.414 3.414a1 1 0 0 1 .293.707V16a1 1 0 0 1-1 1h-1m-6-1a1 1 0 0 0 1 1h1M5 17a2 2 0 1 0 4 0 2 2 0 0 0-4 0zm10 0a2 2 0 1 0 4 0 2 2 0 0 0-4 0z"/></svg>
      </div>
      <div class="toy-ts-text">
        <strong>Fast Delivery</strong>
        <span>Across Pakistan</span>
      </div>
    </div>

  </div>
</div>

<style>
/* ── Trust Strip ─────────────────────────────────────────── */
.toy-trust-strip {
  background: #fff;
  padding: 0 20px;
  margin: 0;
}
.toy-trust-strip__inner {
  display: flex;
  align-items: stretch;
  max-width: 1300px;
  margin: 0 auto;
  background: #fff;
  border-radius: 18px;
  border: 1px solid rgba(15,23,42,0.08);
  box-shadow: 0 4px 20px rgba(15,23,42,0.07);
  overflow: hidden;
  transform: translateY(-50%);
  margin-bottom: -28px;
}
.toy-ts-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px 20px;
}
.toy-ts-divider {
  width: 1px;
  background: rgba(15,23,42,0.07);
  margin: 14px 0;
  flex-shrink: 0;
}
.toy-ts-icon {
  width: 46px;
  height: 46px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.toy-ts-icon--green  { background: #EDFFF5; color: #1FB56D; }
.toy-ts-icon--yellow { background: #FFFBEB; color: #f59e0b; }
.toy-ts-icon--pink   { background: #FFF0F6; color: #F72568; }
.toy-ts-icon--blue   { background: #EFF6FF; color: #3b82f6; }
.toy-ts-text { display: flex; flex-direction: column; gap: 2px; }
.toy-ts-text strong {
  font-size: 13px;
  font-weight: 700;
  color: #111936;
  line-height: 1.2;
}
.toy-ts-text span {
  font-size: 11.5px;
  color: #6b7280;
  line-height: 1.3;
}
@media (max-width: 768px) {
  .toy-trust-strip__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    transform: translateY(-20px);
    margin-bottom: -10px;
    border-radius: 14px;
  }
  .toy-ts-divider { display: none; }
  .toy-ts-item {
    padding: 12px 14px;
    border-bottom: 1px solid rgba(15,23,42,0.06);
  }
  .toy-ts-item:nth-child(odd) { border-right: 1px solid rgba(15,23,42,0.06); }
  .toy-ts-item:nth-last-child(-n+2) { border-bottom: none; }
  .toy-ts-icon { width: 38px; height: 38px; }
  .toy-ts-icon svg { width: 18px; height: 18px; }
  .toy-ts-text strong { font-size: 12px; }
  .toy-ts-text span { font-size: 10.5px; }
}
</style>

{% schema %}
{
  "name": "🎯 Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image (overrides default)",
      "info": "Recommended: 2048 × 720px"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image (overrides default)",
      "info": "Recommended: 800 × 1000px"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Click destination",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "alt",
      "label": "Alt text",
      "default": "Shop Kids Toys Online in Pakistan - Toylicious.pk"
    }
  ],
  "presets": [
    {
      "name": "🎯 Hero Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}
