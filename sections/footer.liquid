{%- liquid
  assign show_selectors = false
  assign currency_selector = false
  assign locale_selector = false

  if section.settings.show_currency_selector and shop.enabled_currencies.size > 1
    assign currency_selector = true
  endif

  if section.settings.show_locale_selector and shop.enabled_locales.size > 1
    assign locale_selector = true
  endif

  if currency_selector or locale_selector
    assign show_selectors = true
  endif
-%}

{%- if settings.color_footer == settings.color_body_bg -%}
  {%- style -%}
    .site-footer {
      border-top: 1px solid {{ settings.color_borders }};
    }
  {%- endstyle -%}
{%- endif -%}

<footer class="site-footer" data-section-id="{{ section.id }}" data-section-type="footer-section">
  <div class="page-width">

    <div class="grid">
      {%- assign row_width = 0 -%}
      {%- for block in section.blocks -%}
        {%- assign row_width = row_width | plus: block.settings.container_width -%}
        {%- if row_width > 100 -%}
          <div class="footer__clear small--hide"></div>
          {%- assign row_width = row_width | minus: 100 -%}
        {%- endif -%}

        <div {{ block.shopify_attributes }} class="grid__item footer__item--{{ block.id }}" data-type="{{ block.type }}">
          {%- style -%}
            @media only screen and (min-width: 769px) and (max-width: 959px) {
              .footer__item--{{ block.id }} {
                width: 50%;
                padding-top: 40px;
              }
              .footer__item--{{ block.id }}:nth-child(2n + 1) {
                clear: left;
              }
            }
            @media only screen and (min-width: 960px) {
              .footer__item--{{ block.id }} {
                width: {{ block.settings.container_width }}%;
              }

            }
          {%- endstyle -%}

          {%- liquid
            case block.type
              when 'logo_social'
                render 'footer-logo', block: block
              when 'custom'
                render 'footer-custom-text', block: block
              when 'newsletter'
                render 'footer-newsletter', block: block
              when 'menu'
                render 'footer-menu', block: block
            endcase
          -%}
        </div>
      {%- endfor -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'logo' -%}
          <div class="grid__item medium-up--hide">
            {%- render 'footer-logo', block: block -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if show_selectors -%}
      <div class="footer__section">
        {%- render 'multi-selectors',
          locale_selector: locale_selector,
          currency_selector: currency_selector,
          show_currency_flags: section.settings.show_currency_flags
          location: 'footer'
        -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_payment_icons -%}
      {%- unless shop.enabled_payment_types == empty -%}
        <ul class="inline-list payment-icons footer__section">
          {%- for type in shop.enabled_payment_types -%}
            <li class="icon--payment">
              {{ type | payment_type_svg_tag }}
            </li>
          {%- endfor -%}
        </ul>
      {%- endunless -%}
    {%- endif -%}

    {%- if section.settings.show_copyright -%}
      <p class="footer__small-text">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
        {%- if section.settings.copyright_text != blank -%}
          {{ section.settings.copyright_text }}
        {%- endif -%}
      </p>
    {%- endif -%}

  </div>
</footer>

<style>
/* ══ MOBILE FOOTER ACCORDION ═══════════════════════════════ */
@media (max-width: 768px) {

  /* Collapsible content — hidden by default on mobile */
  .site-footer .collapsible-content--small {
    height: 0 !important;
    overflow: hidden !important;
    transition: height 0.28s cubic-bezier(0.4,0,0.2,1) !important;
  }
  .site-footer .collapsible-content--small.is-open {
    height: auto !important;
    overflow: visible !important;
  }

  /* Mobile accordion trigger button */
  .site-footer .collapsible-trigger-btn {
    display: flex !important;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px !important;
    background: transparent !important;
    border: none !important;
    border-bottom: 1px solid rgba(255,255,255,0.10) !important;
    cursor: pointer;
    color: #fff !important;
    font-size: 13px !important;
    font-weight: 700 !important;
    letter-spacing: 0.07em !important;
    text-transform: uppercase !important;
    text-align: left;
    min-height: 58px;
    border-radius: 0 !important;
    box-shadow: none !important;
  }
  .site-footer .collapsible-trigger-btn:first-child {
    border-top: 1px solid rgba(255,255,255,0.10);
  }

  /* Chevron icon */
  .site-footer .collapsible-trigger__icon,
  .site-footer .collapsible-trigger-btn .icon {
    color: rgba(255,255,255,0.5) !important;
    flex-shrink: 0;
    transition: transform 0.25s;
    width: 14px;
    height: 14px;
  }
  .site-footer .collapsible-trigger-btn.is-open .collapsible-trigger__icon,
  .site-footer .collapsible-trigger-btn.is-open .icon {
    transform: rotate(180deg);
    color: #F72568 !important;
  }
  .site-footer .collapsible-trigger-btn.is-open { color: #F72568 !important; border-bottom-color: rgba(247,37,104,0.25) !important; }

  /* Content inner padding */
  .site-footer .collapsible-content__inner {
    padding: 12px 20px 20px !important;
  }
  .site-footer .site-footer__linklist li { margin-bottom: 10px; }
  .site-footer .site-footer__linklist a {
    font-size: 14px !important;
    color: rgba(255,255,255,0.75) !important;
    padding: 4px 0;
    display: block;
  }

  /* Desktop title hidden on mobile */
  .site-footer .footer__title.small--hide { display: none !important; }

  /* Newsletter input on mobile */
  .site-footer .newsletter-form__input { background: rgba(255,255,255,0.1) !important; color: #fff !important; }
  .site-footer .newsletter-form__submit { background: #F72568 !important; }
}
/* ══ END MOBILE FOOTER ACCORDION ════════════════════════════ */
</style>

<script>
/* ── Footer mobile accordion JS ─────────────────────────── */
(function() {
  function initFooterAccordion() {
    /* Target only mobile footer toggle buttons */
    var footerBtns = document.querySelectorAll(
      '.site-footer .collapsible-trigger-btn, .site-footer [data-collapsible-id]'
    );

    footerBtns.forEach(function(btn) {
      if (btn.dataset.footerInit) return;
      btn.dataset.footerInit = '1';

      btn.addEventListener('click', function(e) {
        /* Only run on mobile */
        if (window.innerWidth >= 769) return;

        var targetId = btn.getAttribute('aria-controls');
        var content  = targetId ? document.getElementById(targetId) : null;

        /* Fallback: find next sibling collapsible-content */
        if (!content) {
          var next = btn.nextElementSibling;
          while (next && !next.classList.contains('collapsible-content')) {
            next = next.nextElementSibling;
          }
          content = next;
        }
        if (!content) return;

        var isOpen = content.classList.contains('is-open');

        if (isOpen) {
          /* Close */
          content.style.height = content.scrollHeight + 'px';
          requestAnimationFrame(function() {
            content.style.height = '0px';
          });
          content.addEventListener('transitionend', function once() {
            content.removeEventListener('transitionend', once);
            content.classList.remove('is-open');
            content.style.height = '';
          });
          btn.classList.remove('is-open');
          btn.setAttribute('aria-expanded', 'false');
        } else {
          /* Open */
          content.classList.add('is-open');
          content.style.height = '0px';
          requestAnimationFrame(function() {
            content.style.height = content.scrollHeight + 'px';
          });
          content.addEventListener('transitionend', function once() {
            content.removeEventListener('transitionend', once);
            if (content.classList.contains('is-open')) {
              content.style.height = 'auto';
            }
          });
          btn.classList.add('is-open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFooterAccordion);
  } else {
    initFooterAccordion();
  }
})();
</script>

{% schema %}
  {
    "name": "Footer",
    "max_blocks": 12,
    "settings": [
      {
        "type": "header",
        "content": "Language selector",
